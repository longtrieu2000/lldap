# Copy file nay thanh `.env`, sau do thay cac gia tri secret/password.
#
# Lenh goi y:
#   cp .env_default_example .env
#   ./generate_secrets.sh

TZ=Asia/Ho_Chi_Minh
UID=1000
GID=1000

# Bat buoc thay bang chuoi random manh.
LLDAP_JWT_SECRET=REPLACE_WITH_RANDOM_JWT_SECRET

# Bat buoc thay bang chuoi random manh. Khong doi sau khi da co du lieu that.
LLDAP_KEY_SEED=REPLACE_WITH_RANDOM_KEY_SEED

# Base DN cua LDAP. Vi du domain vnpay.vn -> dc=vnpay,dc=vn.
LLDAP_LDAP_BASE_DN=dc=vnpay,dc=vn

# Admin mac dinh: username la `admin`.
LLDAP_LDAP_USER_EMAIL=admin@vnpay.vn
LLDAP_LDAP_USER_PASS=CHANGE_ME_STRONG_PASSWORD

# URL public cua Web UI. Neu dung reverse proxy, doi thanh https://ldap.vnpay.vn.
LLDAP_HTTP_URL=http://localhost:17170

# Tuy chon: bat log chi tiet khi can debug.
# LLDAP_VERBOSE=true

# Tuy chon: dung database ngoai thay SQLite mac dinh.
# LLDAP_DATABASE_URL=postgres://postgres-user:password@postgres-server/lldap
# LLDAP_DATABASE_URL=mysql://mysql-user:password@mysql-server/lldap

# Tuy chon: bat LDAPS. Can mount cert/key vao container trong docker-compose.yml.
# LLDAP_LDAPS_OPTIONS__ENABLED=true
# LLDAP_LDAPS_OPTIONS__CERT_FILE=/certs/fullchain.pem
# LLDAP_LDAPS_OPTIONS__KEY_FILE=/certs/privkey.pem

# Tuy chon: reset mat khau admin khi quen password.
# Chi bat tam thoi, restart container, dang nhap lai, sau do comment dong nay.
# LLDAP_FORCE_LDAP_USER_PASS_RESET=true
